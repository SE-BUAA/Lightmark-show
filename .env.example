# Copy this file to .env on the deployment server and fill secrets there.
# Do not commit the real .env file.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=lightmark
DB_USER=lightmark
DB_PASSWORD=change-me

JWT_SECRET=change-me-to-a-long-random-secret
JWT_ISSUER=lightmark
JWT_EXPIRE_MINUTES=120

# DeepSeek/OpenAI-compatible Chat Completions for itinerary AI.
# DeepSeek official compatible endpoint:
#   https://api.deepseek.com/chat/completions
DEEPSEEK_API_KEY=sk-your-deepseek-key
AI_API_URL=https://api.deepseek.com/chat/completions
# Optional. If empty, backend uses DEEPSEEK_API_KEY for itinerary AI.
AI_API_KEY=sk-your-ai-key
AI_MODEL=deepseek-v4-flash

OPENAI_API_KEY=sk-your-openai-key
OBJECT_STORAGE_BASE_URL=https://objectstorage.ap-tokyo-1.oraclecloud.com/p/lalala/n/guesswhat/b/ortus-bucket/o/
